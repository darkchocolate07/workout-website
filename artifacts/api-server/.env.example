# Required for JWT signing (min 16 characters). Keep secret in production.
JWT_SECRET=change-me-to-a-long-random-string

# Users register via POST /api/auth/signup; login uses the `users` table.

# Optional: Groq for natural-language Ask answers (still grounded on DB retrieval only).
# Get a key at https://console.groq.com — never commit real keys to git.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
